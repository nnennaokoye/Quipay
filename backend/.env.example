PORT=3000

# Stellar Configuration
STELLAR_NETWORK=TESTNET # or PUBLIC
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HOT_WALLET_ACCOUNT=GAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX # Required in non-development environments

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Hashicorp Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here
VAULT_SECRET_PATH=quipay/keys
VAULT_MOUNT_POINT=secret

# Key Rotation Configuration
KEY_ROTATION_ENABLED=false
KEY_ROTATION_CHECK_INTERVAL_MS=86400000
KEY_ROTATION_PERIOD_DAYS=30
KEY_ROTATION_GRACE_PERIOD_DAYS=7
# Redis Configuration (optional - for distributed rate limiting)
# If not set, rate limiting will use in-memory store
REDIS_URL=redis://localhost:6379

# Database / Other Config (Add as needed)
DISCORD_PUBLIC_KEY=your_discord_public_key
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Employer KYB verification
# Optional. When omitted, backend uses a deterministic mock verifier for local/dev flows.
KYB_API_URL=
KYB_API_KEY=
KYB_API_TIMEOUT_MS=5000
